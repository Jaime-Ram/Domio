# Kopieer naar .env in deze map (mobile/.env) en vul in — zelfde Supabase-project als de Next.js app.
# Herstart daarna: npx expo start

EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optioneel: basis-URL van je webapp (voor Registreren / Wachtwoord vergeten in de browser)
EXPO_PUBLIC_WEB_APP_URL=https://jouw-domein.nl
